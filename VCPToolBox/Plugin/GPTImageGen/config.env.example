# GPTImageGen 插件配置
# 复制此文件为 config.env 并填入你的配置

# 必需 - OpenAI 兼容 API 密钥
OPENAI_API_KEY=sk-your-api-key-here

# 必需 - API 基础地址（OpenAI 官方或兼容反代）
OPENAI_BASE_URL=https://api.openai.com

# 可选 - 模型名称（默认 gpt-image-2）
GPT_IMAGE_MODEL=gpt-image-2

# 可选 - 默认图片尺寸（默认 1024x1024，最长边≤3840）
DEFAULT_SIZE=1024x1024

# 可选 - 默认质量（low/medium/high/auto，默认 auto）
DEFAULT_QUALITY=auto

# 可选 - 返回格式（url/b64_json，默认 b64_json）
DEFAULT_RESPONSE_FORMAT=b64_json

# 可选 - 默认背景（transparent/opaque/auto，默认 auto）
DEFAULT_BACKGROUND=auto

# 可选 - Chat Completions 模式（true/false，默认 false）
# 某些兼容渠道不支持 /v1/images/generations 端点，而是通过
# /v1/chat/completions + 内置 image_generation tool 来生成图片。
# 设为 true 可直接使用该模式，无需等待标准端点失败后自动回退。
# 注意：即使不设置此项，插件也会在检测到 "tool choice not found" 错误时自动回退。
USE_CHAT_COMPLETIONS_MODE=false

# 可选 - 调试模式（true/false，默认 false）
DebugMode=false

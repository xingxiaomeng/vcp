# ═══════════════════════════════════════════════════
# ContextFoldingV2 - 上下文语义折叠V2 配置
# ═══════════════════════════════════════════════════

# 摘要生成模型（应选择便宜、快速的模型）
FOLDING_SUMMARY_MODEL=gemini-3.1-flash-lite-preview

# 摘要提示词（系统级指令，要求模型严格输出指定格式）
FOLDING_SUMMARY_SYSTEM_PROMPT=FOLDING_SUMMARY_SYSTEM_PROMPT=上下文压缩器。输出单行格式：[VCP上下文语义折叠-本层摘要:摘要内容]\n规则：\n1.提取：核心动作、关键实体(人名/文件名/工具名/技术概念)、结论与决策、工具调用结果\n2.剥离：寒暄问候、表情符号、语气词、修辞装饰、排版格式、冗余解释\n3.摘要≤100字。

# 摘要用户级提示词模板（{CONTENT} 会被替换为实际内容）
FOLDING_SUMMARY_USER_PROMPT=请严格按以下格式输出一行，不要输出任何其他内容：\n[VCP上下文语义折叠-本层摘要:你的摘要内容]\n\n要求：用一句话概括以下AI回复的核心内容，摘要不超过100字。\n\n---\n{CONTENT}

# 最低折叠触发深度（从最新AI回复往上数，>=此值的AI输出才可能被折叠）
# 系统强制最低为2，即最近2个AI回复始终不会被折叠
FOLDING_MIN_DEPTH=3

# 摘要生成最大重试次数
FOLDING_MAX_RETRIES=3

# 摘要生成最大并发数（队列会限流；默认一次最多 5 个并发请求）
FOLDING_SUMMARY_MAX_CONCURRENT=5
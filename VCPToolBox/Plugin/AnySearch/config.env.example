# 可选：AnySearch API Key。不配置时匿名访问（额度较低）。
# 支持多个 Key 用英文逗号分隔，每次请求随机选用一个，例如：as_sk_xxx,as_sk_yyy
# 获取地址：https://anysearch.com/console/api-keys
ANYSEARCH_API_KEY=

# 可选：JSON-RPC endpoint 覆盖（默认 https://api.anysearch.com/mcp）
ANYSEARCH_ENDPOINT=https://api.anysearch.com/mcp

# 可选：HTTP 请求超时，单位毫秒，范围 1000-120000（默认 30000）
ANYSEARCH_TIMEOUT_MS=30000

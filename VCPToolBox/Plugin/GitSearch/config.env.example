# GitSearch 插件配置文件
# 请填写对应平台的访问令牌，不需要的平台可留空

# GitHub Personal Access Token
# 获取地址: https://github.com/settings/tokens
# 需要的权限: repo (读取仓库信息)
GITHUB_TOKEN=

# GitLab Personal Access Token
# 获取地址: https://gitlab.com/-/profile/personal_access_tokens
# 需要的权限: read_api, read_repository
GITLAB_TOKEN=

# GitLab 实例地址 (自托管请修改)
GITLAB_URL=https://gitlab.com

# Gitee 私人令牌
# 获取地址: https://gitee.com/profile/personal_access_tokens
# 需要的权限: projects, pull_requests, issues, user_info
GITEE_TOKEN=

# ── 输出长度限制 (可选) ──
# 控制返回内容的最大字符数，设为 0 或不设则不限制
# 示例: 8000
MAX_OUTPUT_LENGTH=30000

# ── 代理配置 (可选) ──
# 支持 http://, https://, socks5://, socks4:// 协议
# 示例: http://127.0.0.1:7890  或  socks5://127.0.0.1:10808
# 各平台独立配置，不需要的平台可留空
GITHUB_PROXY=
GITLAB_PROXY=
GITEE_PROXY=

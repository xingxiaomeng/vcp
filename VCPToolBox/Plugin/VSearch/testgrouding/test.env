# Gemini Grounding 测试专用配置
# 运行方式：
#   cd Plugin/VSearch
#   node testgrouding/testgemini.js

# Gemini / NewAPI / OpenAI-compatible 渠道密钥
GEMINI_API_KEY=sk-YourGeminiOrNewApiKeyHere

# OpenAI-compatible chat completions 地址
# Google 官方兼容层示例：
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# NewAPI / 中转渠道示例：
# GEMINI_API_URL=http://127.0.0.1:3000/v1/chat/completions
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions

# 要测试的 Gemini 模型。请换成你的渠道里实际可用且疑似支持 grounding 的模型名。
GEMINI_MODEL=gemini-3.5-flash

# 测试主题。脚本会按 VSearch Grounding 请求结构把它作为 SearchTopic，
# 并把“当前北京时间”注入到当前检索关键词中。
TEST_QUERY=今天的新闻

# 输出与超时
GEMINI_MAX_TOKENS=40960
TEST_TIMEOUT_MS=120000
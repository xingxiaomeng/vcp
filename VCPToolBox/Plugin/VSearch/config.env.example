# ==========================================
# VSearch 全局配置
# ==========================================

# 默认搜索模式。
# 可选值: grounding | grok | tavily | kimisearch
# - grounding: 调用 LLM 的 googleSearch 工具进行搜索 (需配置第 2 节)
# - grok:      调用 Grok 内置搜索 (需配置第 2 节中的 GrokModel)
# - tavily:    调用 Tavily 外部搜索引擎 + 二阶 LLM 总结 (需配置第 3、5 节)
# - kimisearch:调用 Kimi Search API + 二阶 LLM 总结 (需配置第 4、5 节)
SearchMode=kimisearch

# 并发搜索上限。仅 grounding 模式需要（按批次并发调用 LLM）。
MaxConcurrent=5

# LLM 输出最大 token 数。影响所有需要 LLM 生成报告的模式。
VSearchMaxToken=50000


# ==========================================
# 1. Grounding / Grok 模式：直接 LLM 搜索
# ==========================================
# 以下三项是 grounding / grok 模式的必需配置。
# 它们表示：直接调用哪个 LLM API 来执行搜索任务。

VSearchKey=sk-YourAPIKeyHere
VSearchUrl=http://YourApiServerUrl/v1/chat/completions

# Grounding 模式使用的模型。建议具备 googleSearch 工具能力的模型。
# 例如: gemini-2.5-flash-lite-preview-09-2025-thinking
VSearchModel=gemini-2.5-flash-lite-preview-09-2025-thinking

# Grok 模式使用的模型名称。仅 grok 模式读取。
GrokModel=grok-4.20-beta


# ==========================================
# 2. Tavily 模式：外部搜索引擎配置
# ==========================================
# TavilyKey 是 Tavily 搜索引擎本身的 API Key。
# 提示: 也可以放在根目录 config.env 中，插件会优先读取根目录配置。
TavilyKey=tvly-YourTavilyKeyHere


# ==========================================
# 3. KimiSearch 模式：Kimi Search API 配置
# ==========================================
KimiSearchUrl=https://api.kimi.com/coding/v1
KimiSearchKey=sk-YourKimiKeyHere

# 每个关键词返回的最大结果数。范围 1~20，默认 5。
KimiSearchMaxResults=5

# 是否抓取网页完整正文。默认 false。
# 开启后会显著增加 Token 消耗，建议仅在需要深度阅读时启用。
KimiSearchIncludeContent=false


# ==========================================
# 4. 二阶总结模型配置 (用于 tavily / kimisearch)
# ==========================================
# Tavily 和 KimiSearch 的执行分为两个阶段：
#   阶段1: 调用外部搜索引擎获取原始结果
#   阶段2: 调用 LLM 把原始结果整合成结构化研究报告
# 本节配置专门用于阶段2的总结。
#
# 如果本节未配置，插件会回退使用第 1 节的 VSearchKey/VSearchUrl/VSearchModel。
# 但为了职责清晰，强烈建议为阶段2单独配置一个通用 LLM。

SummaryKey=sk-YourSummaryAPIKey
SummaryUrl=https://api.openai.com/v1/chat/completions
SummaryModel=gpt-5.4


# ==========================================
# 5. 网络代理 (可选)
# ==========================================
# 仅用于 grounding 模式下解析 Google Vertex 重定向 URL。
# HTTP_PROXY=http://127.0.0.1:7890

# VCPWeCom 插件环境配置示例 — 复制为 config.env 并填写实际值

# ============================================
# 企业微信机器人（必填）
# 从企业微信智能机器人“长连接模式”后台获取
# ============================================
WeComBotId=你的机器人ID
WeComBotSecret=你的机器人Secret

# ============================================
# 绑定的 Agent（必填）
# 必须是 AgentAssistant config.json 里某个 agent 的 chineseName
# ============================================
WeComBindAgent=nova

# ============================================
# WebSocket 长连接（可选，带默认值）
# ============================================
# 最大重连次数，-1 = 无限重连（生产常驻推荐）
WeComMaxReconnect=-1
# 心跳间隔毫秒
WeComHeartbeatInterval=30000

# ============================================
# 回复策略（可选）
# ============================================
# 是否启用两段式流式回复（先发提示再发全文）
WeComStreamReply=true
# 流式中间提示语
WeComStreamHint=正在思考中…
# agent 推理超时毫秒，超时回退提示语（跟AA插件一致）
WeComAgentTimeoutMs=358000

# ============================================
# 会话与工具（可选）
# ============================================
# 传给 AgentAssistant 的 session_id 前缀
WeComSessionPrefix=wecom
# 唤醒 agent 时临时注入的工具组，逗号分隔
WeComInjectTools=VCPWeCom

# ============================================
# 白名单（可选，强烈建议启用）
# 留空 = 不限制；填 userid 逗号分隔 = 仅这些用户可触发
# ============================================
# WeComAllowedUsers=user1,user2

# ============================================
# 图片/文件处理（可选）
# ============================================
# 图片最大字节数，超过则拒绝处理，默认 10MB
WeComMaxImageBytes=10485760
# 文件最大字节数，超过则拒绝处理，默认 25MB
WeComMaxFileBytes=26214400
# 文件解析超时毫秒，默认 30s
WeComFileParseTimeoutMs=30000

# ============================================
# 调试
# ============================================
DebugMode=false

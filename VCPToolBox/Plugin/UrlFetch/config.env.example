# Jina Reader API Key（可选）
# 不填时使用 https://r.jina.ai/ 免费模式；填写有效 Key 后优先使用鉴权模式，失败会自动回退免费模式。
JINA_API_KEY=

# Jina Reader 请求超时（毫秒）
JINA_READER_TIMEOUT_MS=20000

# 代理端口（可选）
FETCH_PROXY_PORT=7890

# ===== Puppeteer 持久化浏览器 Profile 配置 =====
# 是否启用持久化 Profile。启用后，Puppeteer 会保存 Cookie、LocalStorage、IndexedDB、缓存等浏览器状态。
# 注意：这不是常驻浏览器；浏览器仍会在每次调用结束后关闭，但下次会复用同一个 Profile。
URLFETCH_PERSISTENT_PROFILE=true

# Profile 根目录。留空则默认使用 Plugin/UrlFetch/browser-profiles
URLFETCH_PROFILE_DIR=

# Profile 模式：
# - domain：默认。按域名隔离，并区分 direct/proxy 出口，例如 mp.weixin.qq.com/direct
# - default：所有直连请求共用 default，代理请求共用 proxy_xxx/default
# - proxy-aware：先按 direct/proxy 出口隔离，再按域名隔离
URLFETCH_PROFILE_MODE=domain

# 是否所有 text 请求都优先走 Puppeteer 浏览器路径。
# false 时保持“直接 HTTP 快速读取优先，高风险域名浏览器优先”的策略。
URLFETCH_BROWSER_FIRST=false

# Puppeteer headless 模式：
# - true：无头模式（默认）
# - false：有头模式，适合首次人工登录/验证，状态会保存到 Profile
# - new：使用新版 Chrome Headless
URLFETCH_HEADLESS=true

# 高风险/强动态域名列表。命中后 text 模式会跳过直接 HTTP，优先用 Puppeteer + 持久化 Profile 打开真实页面。
URLFETCH_HIGH_RISK_DOMAINS=mp.weixin.qq.com,zhihu.com,x.com,twitter.com,bilibili.com,weibo.com

# ===== Managed Chrome 后端配置（实验性） =====
# backend 策略：
# - auto：默认。普通页面 direct HTTP 优先，高风险/强动态页面可按配置走 managed Chrome。
# - managed：text 模式强制优先走 VCP 托管 Chrome。
# - puppeteer/direct/jina：禁用 managed backend，保持指定传统路径。
URLFETCH_BROWSER_BACKEND=auto

# 是否允许 UrlFetch 使用 VCP 托管 Chrome 的持久 Profile 作为网页提取后端。
URLFETCH_USE_MANAGED_CHROME=false

# 是否仅高风险/强动态域名走 managed Chrome。设 false 后 text 模式可更积极使用 managed backend。
URLFETCH_MANAGED_CHROME_HIGH_RISK_ONLY=true

# UrlFetch 自动拉起/使用 managed Chrome 后，任务结束是否关闭 managed Chrome 释放内存。
URLFETCH_MANAGED_CHROME_AUTO_CLOSE=true

# UrlFetch 任务结束是否关闭本次抓取标签页。
URLFETCH_MANAGED_CHROME_CLOSE_TAB=true

# ===== Cookies 配置（三选一） =====

# 方式1：单站点原始格式（最简单，适合只访问一个网站）
# 直接粘贴从浏览器复制的 cookie 字符串
# 示例：SESSDATA=abc123; bili_jct=xyz789; DedeUserID=12345
# 注意：访问任何网站都会使用这些 cookies
FETCH_COOKIES_RAW=

# 方式2：多站点原始格式（推荐，支持多个网站）
# JSON 对象格式，key 是域名关键词，value 是 cookie 字符串
# 会根据访问的 URL 自动匹配对应的 cookies
# 示例：{"bilibili.com":"SESSDATA=abc123; bili_jct=xyz","twitter.com":"auth_token=xxx; ct0=yyy"}
FETCH_COOKIES_RAW_MULTI=

# 方式3：JSON 数组格式（高级用户，支持最多参数）
# 格式示例：[{"name":"session_id","value":"abc123","domain":".example.com"}]
# 完整参数示例：[{"name":"token","value":"xxx","domain":".example.com","path":"/","expires":-1,"httpOnly":false,"secure":true,"sameSite":"Lax"}]
FETCH_COOKIES=

# 优先级：FETCH_COOKIES_RAW_MULTI > FETCH_COOKIES_RAW > FETCH_COOKIES
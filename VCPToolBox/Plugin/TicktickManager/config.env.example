# TicktickManager 配置示例
# 国际版默认：https://api.ticktick.com/open/v1
# 国内版滴答清单：https://api.dida365.com/open/v1
TICKTICK_BASE_URL=https://api.dida365.com/open/v1

# 鉴权
# 只填写 TICKTICK_ACCESS_TOKEN。滴答清单当前不再提供刷新令牌；本插件不会自动获取或刷新 token。
# 若 access token 缺失、错误或过期，请在插件根目录使用独立脚本 auth-cli.js 或按官方方式获取新 token，填入后重启 VCPToolBox。
TICKTICK_ACCESS_TOKEN=

# 以下 OAuth 字段仅供独立脚本 auth-cli.js 获取 TICKTICK_ACCESS_TOKEN 时使用，插件运行时不读取。
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
TICKTICK_REDIRECT_URI=http://localhost:8000/callback
TICKTICK_OAUTH_SCOPE="tasks:read tasks:write"
TICKTICK_AUTH_URL=
TICKTICK_TOKEN_URL=

# 收集箱真实项目 ID，仅在项目清单填写 "收集箱" 或 "inbox" 时使用
# 必须手动填写真实 inbox+数字串；留空则跳过收集箱，不自动请求探测
TICKTICK_INBOX_PROJECT_ID=

# 仅允许创建任务和子任务的项目清单
# 注意：每个项目项必须独立使用英文双引号包裹，再用英文逗号分隔
# 项目项支持项目 ID 或唯一项目名称；长期建议使用项目 ID
TICKTICK_CREATE_ONLY_PROJECTS="收集箱","某个只准新增的清单ID"

# 允许创建、更新、完成、删除、读取、搜索的项目清单
# 注意：每个项目项必须独立使用英文双引号包裹，再用英文逗号分隔
# 项目项支持项目 ID 或唯一项目名称；长期建议使用项目 ID
TICKTICK_FULL_ACCESS_PROJECTS="工作","某个全权限清单ID"

# 调试日志
DebugMode=false

# 火山引擎 API 密钥
# 从 https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey 获取
# 支持多个API密钥，用英文逗号分隔，系统会顺序轮询使用
# 如果某个密钥配额用完，会自动尝试其他密钥
# 示例：VOLCENGINE_API_KEY=key1,key2,key3
VOLCENGINE_API_KEY=your_api_key_here

# 默认模型ID（可通过 list_models 命令动态查询可用模型）
# SEEDREAM_MODEL_ID=doubao-seedream-5-0-260128

# 是否默认添加水印 (true/false)
DEFAULT_WATERMARK=false

# 默认返回格式 (url 或 b64_json)
# url: 返回图片链接（24小时有效）
# b64_json: 返回Base64编码（多模态AI可以直接看到图片）
DEFAULT_RESPONSE_FORMAT=b64_json

# 调试模式 (true/false)
DebugMode=false

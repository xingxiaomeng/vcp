# AICodeWorker 配置文件
# 复制为 config.env 后修改生效，修改后无需重启 VCP（插件热加载）

# ── Worker 开关 ─────────────────────────────────────
ENABLE_OPENCODE=true
ENABLE_MIMOCODE=false

# ── OpenCode 配置 ───────────────────────────────────
# opencode 可执行文件路径（在 PATH 中则填 opencode 即可）
OPENCODE_BIN=opencode

# 模型路由（两种模式，二选一）
#
# 【模式A - 推荐】用 opencode 自带的【免费】模型，不消耗你自己的 token
#   规则：OPENCODE_BASE_URL 和 OPENCODE_API_KEY 必须【都留空】，
#         在 OPENCODE_MODEL 填一个 opencode/ 开头的免费模型。
#   注意：opencode 免费模型走它官方的远程网关，服务器需要能访问外网（必要时挂代理）。
#   ⚠️ 不要把 OPENCODE_MODEL 也留空——留空会回退到 opencode 的付费默认模型
#      （如 gpt-5.x，需要 OpenAI key），并非免费。
#
#   可用免费模型（用 `opencode models | grep opencode/` 查看最新清单）：
#     opencode/deepseek-v4-flash-free   # 推荐，代码能力强、速度快、综合均衡
#     opencode/north-mini-code-free     # 代码专用轻量模型，适合简单分析/小 patch
#     opencode/mimo-v2.5-free           # 通用对话型
#     opencode/big-pickle               # opencode 实验模型
#   （免费模型由官方提供，可能有速率/并发限制，繁忙时换一个再试）
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
OPENCODE_MODEL=opencode/deepseek-v4-flash-free
#
# 【模式B - 进阶】把 opencode 的模型请求路由到你自己的模型（会消耗你的 token）
#   规则：OPENCODE_BASE_URL 和 OPENCODE_API_KEY 都填上即自动切到模式B。
#   ⚠️ 别用"推理模型"（正式输出为空、内容全在 reasoning 里），opencode 会一直等内容卡死；
#      要用直接出内容的模型。
# OPENCODE_BASE_URL=http://127.0.0.1:6005/v1
# OPENCODE_API_KEY=your_api_key_here
# OPENCODE_MODEL=your-model-name

# ── 安全配置 ────────────────────────────────────────
# 允许操作的项目根目录白名单（逗号分隔），projectPath 必须在其中
ALLOWED_PROJECT_ROOTS=/app/VCPToolBox_new

# 任务输出目录（output/logs/patches/meta 均在此目录下）
JOB_ROOT=/app/VCPToolBox_new/Plugin/AICodeWorker/jobs

# 单次任务最大字符数
MAX_TASK_CHARS=20000

# 默认超时（秒）
DEFAULT_TIMEOUT_SEC=600

# 是否让 analyze/patch 模式也跳过 opencode 权限确认（默认关闭）
# 注意：write 模式恒自动跳过权限（代码强制 line556），此开关对 write 模式无效。
# 仅作用于 analyze/patch（只读,意义有限）。安全靠 mode=write门槛 + ALLOWED_PROJECT_ROOTS白名单 + 任务约束词。
ALLOW_DANGEROUS_SKIP_PERMISSIONS=false

# 是否脱敏输出中的密钥/Token
REDACT_SECRETS=true

# ── Antigravity (agy) worker — 复杂/严谨任务专用 ──────────
# agy = Google Antigravity CLI（类似 opencode 的终端编程 agent，但跑 Gemini 3 等强模型）。
# 开启后多一个 worker=antigravity：复杂、需严谨代码逻辑/设计的任务派给它；常规活仍用 opencode。
# ⚠️ 成本：agy 走你的 Google/Gemini Pro 账号配额（约 1500 次/天、60 次/分钟），不是无限免费！
#         默认 worker 仍是 opencode（免费），只有【点名 antigravity】或【复杂任务】才用 agy。
# 关闭(false)时：插件行为与从前完全一致，只用 opencode。
ENABLE_ANTIGRAVITY=false

# agy 可执行文件路径。
# ⚠️ 强烈建议填【绝对路径】：VCP(pm2)进程 PATH 通常不含 ~/.local/bin，只填 agy 会找不到。
#    用 `which agy` 查实际路径（一般是 /home/<用户名>/.local/bin/agy）。
AGY_BIN=/home/youruser/.local/bin/agy

# agy 模型。留空 = 用 agy 登录时的默认模型（通常 Gemini 3.5 Flash (High)）。
# 调用插件时也可传 model 参数按任务难度临时覆盖（最难的活用最强模型）。
# 可用模型（用 `agy models` 查最新；填下面 label 全名，含括号）：
#   Gemini 3.5 Flash (High)        # 默认；快，中等复杂度
#   Gemini 3.5 Flash (Medium)
#   Gemini 3.5 Flash (Low)
#   Gemini 3.1 Pro (High)          # 最强；严谨架构/难 bug 首选
#   Gemini 3.1 Pro (Low)
#   Claude Opus 4.6 (Thinking)     # Anthropic 强模型（经 agy 平台）
#   Claude Sonnet 4.6 (Thinking)
#   GPT-OSS 120B (Medium)
AGY_MODEL=

# agy 连 Google 必需的代理。
# agy 要访问 Google/Gemini API；服务器在墙内时必须经此代理，否则任务超时失败。
# 填本地代理（Clash 默认 http://127.0.0.1:7890）；服务器能直连 Google 才可留空。
# 这一项配错 = agy 连不上。
AGY_PROXY=http://127.0.0.1:7890

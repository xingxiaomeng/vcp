# 必填：ClawEmail API Key
# 注意：这不是 npx @clawemail/claw-setup --auth-url 后面的临时 URL。
# auth-url 只用于官方一键安装/授权流程；这里需要最终可供 SDK 使用的 API Key。
ClawMailKey=

# 必填：需要管理/轮询的 ClawEmail 邮箱，多个用英文逗号分隔。
# 第一个邮箱会作为默认邮箱，除非显式设置 ClawMailDefaultUser。
ClawMailUsers=bot@claw.163.com

# 可选：默认读取/发件邮箱。
ClawMailDefaultUser=bot@claw.163.com

# 可选：4 个 Agent 子邮箱。公共邮箱逻辑不受影响；子邮箱收到 WebSocket 新邮件后会自动读取邮件并通过 AgentAssistant 联系绑定 Agent。
# 每组必须同时配置 User 和 Agent 才会启用。工具调用时可用 mailbox=mail1/mail2/mail3/mail4 指定子邮箱。
# 默认使用 AgentAssistant 正常通讯分支（进入持续上下文）；如需让某个 Agent 后台处理复杂长任务，可把对应 AsyncDelegation 设为 true。
# 异步委托模式会提交 AgentAssistant task_delegation，适合视频生成/长文件处理/多轮工具任务；Agent 完成后应调用 VCPClawMail reply_mail 给原邮件回复报告。
# ClawMailSubMail1User=vcp.x1@claw.163.com
# ClawMailSubMail1Agent=小助手一
# ClawMailSubMail1AsyncDelegation=false
# ClawMailSubMail2User=vcp.x2@claw.163.com
# ClawMailSubMail2Agent=小助手二
# ClawMailSubMail2AsyncDelegation=false
# ClawMailSubMail3User=vcp.x3@claw.163.com
# ClawMailSubMail3Agent=小助手三
# ClawMailSubMail3AsyncDelegation=false
# ClawMailSubMail4User=vcp.x4@claw.163.com
# ClawMailSubMail4Agent=小助手四
# ClawMailSubMail4AsyncDelegation=false
#
# 兼容简写变量名：Mail1/mail1 + AgentName1/agentname1 + AgentAsyncDelegation1/agentasyncdelegation1 等也会被识别，但推荐使用上面的 ClawMailSubMail* 命名。

# 可选：子邮箱自动投递 Agent 时，每封邮件最多自动读取/解析多少个附件。默认 8。
ClawMailSubMailAutoMaxAttachments=8

# 可选：每个子邮箱保留多少个已自动处理 mailId，用于 WebSocket 重连/重复推送幂等去重。默认 500。
ClawMailSubMailProcessedKeep=500

# 可选：WebSocket 即达推送，默认启用；禁用后仅保留低频轮询兜底，子邮箱自动唤醒 Agent 也不会触发。
ClawMailRealtimeEnabled=true

# 可选：覆盖 SDK 默认 WuKongIM WebSocket 地址，通常无需填写。
# ClawMailWsUrl=wss://claw.126.net:5210

# 可选：常驻轮询间隔，毫秒。默认 60000。
ClawMailPollIntervalMs=60000

# 可选：每个邮箱缓存最近邮件数量。默认 20。
ClawMailPollLimit=20

# 可选：read_mail 未传 markRead 时是否默认标记已读。默认 false。
ClawMailAutoMarkRead=false

# 可选：调试日志。
DebugMode=false

# 可选：网络代理。用于 SDK 请求（ClawEmail API）和附件下载。
# 支持 http/https 代理，格式如 http://host:port 或 http://user:pass@host:port
# 也支持读取系统环境变量 HTTPS_PROXY / HTTP_PROXY。
ClawMailProxy=

# DailyNoteSearcher 常驻 HTTP 服务绑定地址。默认只监听本机回环地址。
DAILY_NOTE_SEARCHER_HOST=127.0.0.1

# DailyNoteSearcher 常驻 HTTP 服务固定端口，供 RAGDiary 和其他模块统一调用。
DAILY_NOTE_SEARCHER_PORT=38765

# DailyNoteSearcher direct/HTTP 调用超时时间（毫秒）。
DAILY_NOTE_SEARCHER_TIMEOUT=60000

# 默认搜索根目录的相对路径（相对于项目根目录）。
# 可在调用参数 root_path 中覆盖为 knowledge，用于搜索冷知识库文件。
DAILY_NOTE_ROOT=dailynote

# 单次搜索返回的最大结果数量
MAX_RESULTS=20

# 搜索时需要忽略的文件夹列表，用逗号分隔
IGNORED_FOLDERS=VectorStore,DebugLog

# 允许搜索的文件扩展名白名单，用逗号分隔
ALLOWED_EXTENSIONS=md,txt,json,html
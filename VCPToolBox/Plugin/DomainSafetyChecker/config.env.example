# DomainSafetyChecker 代理配置示例
# 复制本文件为 config.env 后按需修改。
#
# 是否启用代理。启用后，工具会先直连访问；若访问失败或遇到 403/407/408/429/5xx 等状态码，
# 会使用 DOMAIN_SAFETY_PROXY_URL 自动重试 HTTP/HTTPS 页面请求和外部脚本请求。
DOMAIN_SAFETY_PROXY_ENABLED=false

# HTTP/HTTPS 代理地址，常见本地代理示例：
# DOMAIN_SAFETY_PROXY_URL=http://127.0.0.1:7890
# DOMAIN_SAFETY_PROXY_URL=http://127.0.0.1:10809
# DOMAIN_SAFETY_PROXY_URL=socks5://127.0.0.1:1080
#
# 注意：Python 标准库 urllib 对 socks5 代理依赖运行环境支持；如不可用，建议使用 http 代理入口。
DOMAIN_SAFETY_PROXY_URL=http://127.0.0.1:7890

# 是否在直连失败时自动使用代理重试。
DOMAIN_SAFETY_PROXY_RETRY_ON_FAILURE=true
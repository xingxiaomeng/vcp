# AgnesVideoGen 插件配置示例
# 把这个文件复制成 config.env，填入真实的 API 密钥即可。

# 你的 agnes 账号钥匙（必填），没有它无法调用视频生成。
AGNES_VIDEO_API_KEY=your_agnes_api_key_here

# 视频生成模型（一般不用改）。
AGNES_VIDEO_MODEL=agnes-video-v2.0

# 默认视频分辨率（宽x高，单位像素）。
AGNES_VIDEO_DEFAULT_WIDTH=1152
AGNES_VIDEO_DEFAULT_HEIGHT=768

# 默认帧数（必须满足 8n+1，比如 81/121/161/241/441）。
# 121 帧 ÷ 24fps ≈ 5 秒；241 帧 ÷ 24fps ≈ 10 秒；441 帧 ÷ 24fps ≈ 18 秒。
AGNES_VIDEO_DEFAULT_NUM_FRAMES=121

# 默认帧率（每秒多少帧，1-60）。帧率越高越流畅，但同样帧数下时长更短。
AGNES_VIDEO_DEFAULT_FRAME_RATE=24

# 最长等待时间（秒）。视频生成慢，默认等 8 分钟，超了就报超时。
AGNES_VIDEO_MAX_WAIT_SECONDS=480

# 注：图片/视频链接用"对外地址"还是"内部地址"的开关(USE_PUBLIC_URL)，
# 已统一放在主 config.env 里，这里不用再写，改一处全局生效。

# 调试模式（true/false）：打开后会输出更多日志，平时关着。
# DebugMode=false

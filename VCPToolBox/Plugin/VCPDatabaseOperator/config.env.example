# ================================================================
# VCPDatabaseOperator · 数据库操作插件配置示例
# ----------------------------------------------------------------
# 用途: 让 VCP Agent 在「表白名单 + CRUD 权限矩阵」边界内
#       安全操作指定数据库的指定表
# 安全: SQL注入物理隔绝(参数化绑定+标识符正则+不收裸SQL)
#       + MyBatis级拦截链 + Druid级连接池管理
# 用法: cp config.env.example config.env 之后填入真实值
# 修改后必须 pm2 restart VCPToolBox 才能生效
# ================================================================


# ---------------- 【1】数据库连接 ----------------

# 数据库类型 (当前仅支持 mysql)
DB_TYPE=mysql

# 数据库主机地址 (IP或域名，不带端口)
DB_HOST=localhost

# 数据库端口 (MySQL默认3306)
DB_PORT=3306

# 数据库登录用户名
# ⚠️ 强烈建议: 创建专属账号，只授本插件需要的库+表权限，不要用root
DB_USER=vcp_app

# 数据库登录密码
# ⚠️ 切勿提交真实密码到Git，本文件(.example)仅做格式参考
DB_PASSWORD=your_password_here

# 目标数据库名 (插件只在此库内操作，不可跨库)
DB_NAME=your_database_name

# 字符集 (建议utf8mb4完整支持emoji)
DB_CHARSET=utf8mb4

# 时区 (例: +08:00 对应Asia/Shanghai)
DB_TIMEZONE=+08:00


# ---------------- 【2】连接池配置 (对应Druid连接池) ----------------

# 最大连接数，AI再疯狂也只能排队，不会无限建连接
DB_POOL_SIZE=5

# 排队获取连接超时(ms)，超时报错而不是无限等待
DB_POOL_ACQUIRE_TIMEOUT=5000

# 连接保活间隔(ms)，防止数据库断线后连接池假死
DB_KEEPALIVE_INTERVAL=10000


# ---------------- 【3】AI抽风熔断 (对应Druid WallFilter) ----------------

# 每分钟最大请求次数(所有操作合计)，超出返回 RATE_LIMIT_EXCEEDED
# 按调用方Agent(maid)分桶，各Agent独立计数互不影响
DB_RATE_LIMIT_PER_MINUTE=60

# 写操作(增/改/删)每分钟单独限制，比读更严
DB_WRITE_RATE_LIMIT_PER_MINUTE=20


# ---------------- 【4】单次查询约束 ----------------

# 单次查询最多返回行数，超出自动截断并告知AI
DB_MAX_ROWS=1000

# SQL执行超时(ms)，超时强制终止查询
DB_QUERY_TIMEOUT=30000

# UPDATE/DELETE预估影响行数超过此值，强制返回确认请求
# AI需要带 confirm:true 重试才能继续
DB_WRITE_MAX_AFFECT_ROWS=100

# 慢查询阈值(ms)，超过此值在返回结果里附带SLOW_QUERY告警
# 对应Druid StatFilter慢SQL监控
DB_SLOW_QUERY_THRESHOLD=2000

# 是否在返回结果里附带执行耗时(方便AI感知性能)
DB_RETURN_DURATION=true

# 单次返回数据总大小上限(字节)，防止大字段OOM，默认5MB
DB_MAX_RESPONSE_BYTES=5242880


# ---------------- 【5】表白名单 + 权限组 ----------------
#
# 权限组说明 (对应MyBatis ResultMap + 权限拦截器):
#   READONLY     只读          → 只能查询
#   READ_INSERT  只读+新增     → 能查、能增，不能改删
#   READ_WRITE   读写          → 能查、能增、能改，不能删
#   FULL         全权限        → 查增改删全开
#
# 格式: DB_TABLE_表名=权限组
# ⚠️ 不在此处配置的表，任何操作都会被拒绝
# ⚠️ 表名必须严格匹配MySQL实际表名(区分大小写)
# ⚠️ 表名只允许字母数字下划线 [a-zA-Z0-9_]
#
DB_TABLE_blog_album=READONLY
DB_TABLE_sys_access_log=FULL
DB_TABLE_article=READ_WRITE
DB_TABLE_comment=READ_INSERT


# ---------------- 【6】字段级保护 (对应MyBatis ResultMap字段过滤) ----------------
#
# 敏感字段黑名单: 这些字段永远不出现在查询返回结果里
# 即使AI在columns里显式指定也会被过滤掉
# 格式: DB_EXCLUDE_COLUMNS_表名=字段1,字段2
#
# DB_EXCLUDE_COLUMNS_user=password_hash,salt,secret_key
#
# 大字段懒加载: 默认SELECT *时排除这些大字段，AI需显式指定才返回
# 格式: DB_LAZY_COLUMNS_表名=字段1,字段2
#
# DB_LAZY_COLUMNS_article=content,cover_base64
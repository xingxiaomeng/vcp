# 动态工具清单桥接器私有配置
# 将本文件复制为 config.env 后填写本地配置。config.env 已被 git 忽略，不会提交到仓库。
# 该配置用于 {{VCPDynamicTools}} 的后台增量分类，不会让本插件变成 LLM 可调用工具。
# 请求格式固定为 OpenAI 兼容 chat completions，不需要配置其他供应商协议。

# 是否启用小模型增量分类。
# 仅新增插件、插件说明变化或手动重建分类时调用，不进入普通请求主路径。
SmallModel_Enabled=false

# 是否复用主配置的上游 API。
# true：自动使用 VCPToolBox/config.env 里的 API_URL 和 API_Key，此时只需要填写 SmallModel_Model。
# false：使用下面的 SmallModel_Endpoint、SmallModel_API_Key 和 SmallModel_Model 作为独立配置。
SmallModel_Use_Main_Config=true

# 用于插件语义分类的轻量模型名称。
# 复用主配置时只需要填这一项。
SmallModel_Model=

# 独立 OpenAI 兼容端点。
# 仅 SmallModel_Use_Main_Config=false 时填写。
# 可以填基础地址，例如 https://example.com，系统会自动补全 /v1/chat/completions。
# 也可以直接填完整地址，例如 https://example.com/v1/chat/completions。
SmallModel_Endpoint=

# 独立端点的 API Key。
# 仅 SmallModel_Use_Main_Config=false 时填写。
# 复用主配置时会自动使用主 config.env 的 API_Key，不读取这里。
SmallModel_API_Key=

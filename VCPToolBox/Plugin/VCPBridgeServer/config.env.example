# VCPBridgeServer - System Prompt 劫持代理配置
# 该插件现在始终以 bridge-config.json 为运行真相源。
# 首次启动时如果 bridge-config.json 不存在，会先从本目录 config.env 迁移；
# 如果本目录 config.env 不存在，则从本示例文件生成 bridge-config.json。
# 后续推荐在管理面板「核心 -> 前端劫持配置」中编辑并保存。

# Bridge Server 独立监听端口（不占用主服务器端口）
BRIDGE_PORT=3100

# 上游 API 地址
# 默认自动指向本地 VCP 主服务器（http://127.0.0.1:{主服务器PORT}），无需手动填写。
# 仅当你需要绕过 VCP 直接转发到外部 API 时才需要修改此项。
# BRIDGE_UPSTREAM_URL=https://api.openai.com
BRIDGE_UPSTREAM_URL=

# 上游 API Key
# 默认自动使用主服务器的 Key（config.env 中的 Key），无需手动填写。
# 仅当 UPSTREAM_URL 指向外部 API 时才需要填写。
BRIDGE_UPSTREAM_KEY=

# 上游 API 类型：chat / anthropic / gemini
# 当上游是本地 VCP 主服务器时固定为 chat，无需修改。
# 仅当直接转发到外部 Anthropic/Gemini API 时才需要改。
BRIDGE_UPSTREAM_TYPE=chat

# 默认模型名（下游请求未指定模型时使用）
BRIDGE_MODEL=gpt-4.1-mini

# System Prompt 劫持内容
# 可以直接写 prompt 文本，也可以写 .txt 文件名（从插件目录加载）
# 示例：BRIDGE_SYSTEM_PROMPT=my_agent_rules.txt
BRIDGE_SYSTEM_PROMPT=

# 劫持模式：
#   replace  - 完全替换原有的所有 system 消息
#   prepend  - 在原有消息最前面插入一条新的 system 消息
#   append   - 在最后一条 system 消息后面追加一条新的 system 消息
#   merge    - 将注入内容与原有所有 system 消息按顺序合并为一条置顶 system 消息
#   off      - 不劫持，纯透传
BRIDGE_HIJACK_MODE=off

# 模型名映射（逗号分隔，冒号分割别名和目标）
# 示例：gpt-4o:claude-sonnet-4,gpt-4:gemini-2.5-pro
BRIDGE_MODEL_MAP=

# 是否输出桥接代理调试日志
DebugMode=false
# --- FileTreeGenerator 插件配置 ---

# 设置你希望扫描的目标文件夹的绝对路径。
# 例如 (Windows): TARGET_DIRECTORY=C:\Users\YourUser\Documents
# 例如 (Linux/macOS): TARGET_DIRECTORY=/home/YourUser/Documents
TARGET_DIRECTORY=

# 设置你希望在扫描中排除的文件夹名称列表，用逗号分隔，不要有空格。
# 例如: EXCLUDE_DIRS=.git,node_modules,.obsidian,target
EXCLUDE_DIRS=

# 设置最大递归深度。0 表示无限制（向下兼容默认行为），正整数表示最大层级深度。
# 例如: MAX_DEPTH=3 表示只展示到第 3 层子目录
MAX_DEPTH=0
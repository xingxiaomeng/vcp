# Rerank 重排查询相关
RerankMultiplier=2
RerankUrl=your url
RerankApi=your api
RerankModel=Qwen/Qwen3-Reranker-8B
RerankMaxTokensPerBatch=30000

# AI级回忆相关
AIMemoModel=
AIMemoBatch=5
AIMemoUrl=your url
AIMemoApi=your api
AIMemoMaxTokensPerBatch=60000
AIMemoPrompt=AIMemoPrompt.txt

# 缓存配置清单
RAG_CACHE_MAX_SIZE=100           
RAG_CACHE_TTL_MS=3600000 

# 向量缓存配置
EMBEDDING_CACHE_MAX_SIZE=500       
EMBEDDING_CACHE_TTL_MS=7200000      

# 开启结果缓存
RAG_QUERY_CACHE_ENABLED=true

# 新对话 K 补偿倍率：当上下文 assistant 块 < 2 时放大 RAG 检索 K，默认 1.2
RAG_FRESH_CONVERSATION_K_MULTIPLIER=1.2

# 上下文完整向量化索引
CONTEXT_VECTOR_ALLOW_API_HISTORY=false

# ::Base64Memo 语法召回多模态附件的最大数量限制，默认 5
BASE64_MEMO_LIMIT=5

# 上下文折叠 SQLite 迷你数据库存储上限
# 最大保存条目数，默认 200；达到上限时按 updated_at 最旧优先 LRU 淘汰
FOLDING_STORE_MAX_ENTRIES=200
# 每次超限时批量淘汰的条目数，默认 20
FOLDING_STORE_EVICT_COUNT=20

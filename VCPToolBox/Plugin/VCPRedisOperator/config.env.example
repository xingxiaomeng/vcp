# ================================================================
# VCPRedisOperator · Redis 操作插件配置示例
# ----------------------------------------------------------------
# 用途: 让 VCP Agent 在「命令白名单 + Key 前缀白名单」边界内
#       安全操作 Redis 数据
# 核心场景: SQL大师写入通知后 INCR user:unread:{userId}，
#           触发前端 SSE 实时角标（Java 侧 Redis Pub/Sub 依赖此计数）
# 用法: cp config.env.example config.env 之后填入真实值
# 修改后必须 pm2 restart VCPToolBox 才能生效
# ================================================================


# ---------------- 【1】Redis 连接 ----------------

# Redis 主机地址（IP 或域名，不含端口）
REDIS_HOST=127.0.0.1

# Redis 端口，默认 6379
REDIS_PORT=6379

# Redis 登录密码（无密码则留空）
REDIS_PASSWORD=

# Redis 数据库编号（0~15，默认 0）
REDIS_DB=0


# ---------------- 【2】连接池 ----------------

# 最大并发连接数
REDIS_POOL_SIZE=5

# 连接超时（ms）
REDIS_CONNECT_TIMEOUT=5000

# 命令执行超时（ms）
REDIS_COMMAND_TIMEOUT=5000


# ---------------- 【3】限频熔断 ----------------

# 所有操作每分钟上限（按调用 Agent maid 分桶）
REDIS_RATE_LIMIT_PER_MINUTE=120

# 写操作（SET/DEL/INCR/EXPIRE 等）每分钟单独限制
REDIS_WRITE_RATE_LIMIT_PER_MINUTE=60


# ---------------- 【4】Key 前缀白名单 ----------------
#
# 格式: REDIS_KEY_PREFIX_N=前缀字符串
# N 从 0 开始，可配置多个，Agent 只能操作匹配前缀的 Key
# 若不配置任何前缀，则允许所有 Key（不推荐生产使用）
#
# 当前 vcp-core 项目所需前缀：
REDIS_KEY_PREFIX_0=user:unread:
# REDIS_KEY_PREFIX_1=user:ban:
# REDIS_KEY_PREFIX_2=captcha:ticket:


# ---------------- 【5】调试 ----------------

# 是否打印每次命令执行日志（生产建议 false）
REDIS_DEBUG=false

# Zhihu OpenAPI Access Secret.
# Copy this file to config.env and fill in the real value. Do not commit config.env.
ZHIHU_ACCESS_SECRET=your_zhihu_access_secret_here

# Optional. Defaults to https://developer.zhihu.com
ZHIHU_OPENAPI_BASE_URL=https://developer.zhihu.com

# Optional full endpoint override. Leave empty for the default zhihu_search path.
ZHIHU_ZHIHU_SEARCH_URL=

# Optional full endpoint override. Leave empty for the default global_search path.
ZHIHU_GLOBAL_SEARCH_URL=

# Optional HTTP timeout in seconds, clamped to 1-60.
ZHIHU_SEARCH_TIMEOUT_SECONDS=5

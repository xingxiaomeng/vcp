# OpenHerPersona 插件配置模板
# 仅在需要本地覆盖配置时复制为 config.env。
# v0.6 起为纯异步观测器：不注入提示词、不写 brk、不写 HTML hint、不要求 persona_delta 回填。

# 启用观测器逻辑。为 false 时，processMessages 原样放行且不入队观测；
# status/explain/config 仍可用于查看配置与架构边界。
OpenHerPersonaEnabled=true

# 异步观测。为 true 时，processMessages 立即返回原 messages，
# 后台按 Agent 独立队列执行向量化、二级残差打分、soft 杠杆耦合与 SQLite 落库。
# 为 false 仅用于诊断：会同步完成观测，但仍然不会注入任何提示词。
OpenHerPersonaAsyncObservation=true

# 每个 Agent 的后台观测队列上限。并发请求会按 Agent 串行处理，
# 超出上限时丢弃最旧的待处理任务，避免观测堆积阻塞主进程。
OpenHerPersonaQueueMaxSize=64

# 单次消息向量化超时时间（毫秒）。锚点冷启动会使用该值的 4 倍。
OpenHerPersonaEmbeddingTimeoutMs=2500

# 二级子锚 softmax 温度。越小越偏向最相近子轴，越大越平滑。
OpenHerPersonaAnchorTemperature=0.12

# 状态 EMA 响应率。越大代表当前观测越快写入状态，越小代表惯性更强。
OpenHerPersonaStateEma=0.35

# 三方 soft 杠杆强度。用于知性 / 感性 / 驱力之间的目标值软牵引。
# 0 表示完全不做层间牵引，只记录独立轴体观测。
OpenHerPersonaCouplingStrength=0.18

# 启动时清理旧版 openher_persona_* 状态表与旧 JSON 状态。
# 新版使用 openher_axis_* 表族，不迁移旧版 frustration/signals/persona_delta 数据。
OpenHerPersonaDropLegacyState=true

# 标准 VCP 调试标志。
DebugMode=false

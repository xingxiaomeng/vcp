# OneRing 统一上下文系统配置示例
# 复制本文件为 config.env 后生效：
#   Plugin/OneRing/config.env.example -> Plugin/OneRing/config.env
#
# 触发方式仍由系统提示词精细控制：
#   [[OneRing::小克::Vchat]]
# 只写库不追加可使用：
#   [[OneRing::小克::Vchat::Only]]
# 或保持主触发不变，额外增减独立开关：
#   [[OneRing::Only]]
#
# 说明：
# - OneRing 是 messagePreprocessor，启用/禁用、最大补充上下文数、时间线插入与来源标记输出位置
#   已迁移到 OneRingConfig.json，并支持 chokidar 热加载，无需重启服务器。
# - 这些 env 配置也可放在根 config.env 中；插件目录 config.env 优先级更高。
# - 默认配置偏保守，推荐先以记录/标记为主，确认稳定后再逐步开启跨端补充。

# ─────────────────────────────────────────────────────────────
# 来源身份
# ─────────────────────────────────────────────────────────────

# 当 user 块没有群聊发言头、AA 通讯标记等来源前缀时，
# 将其视为真正用户发言，并使用此名称作为 senderName。
#
# 示例：
#   普通用户输入："今天晚上吃什么？"
#   入库 senderName=Ryan
ONERING_USER_NAME=Ryan


# ─────────────────────────────────────────────────────────────
# 上下文补充策略
# ─────────────────────────────────────────────────────────────

# 是否允许跨端补充。
# true：允许 OneRing 在安全条件满足时，从同 Agent 的其他前端时间线补入消息。
# false：不做跨端补充，只记录、标记、更新数据库。
ONERING_ALLOW_CONTEXT_PATCH=true

# 是否只记录不改写上下文。
# true：最保守模式。只做记录、尾部标记、retry 更新，不主动补充跨端上下文。
# false：在 fuzzy diff 可靠、未知比例低、允许跨端补充时，才尝试插入其他前端消息。
#
# 推荐初期保持 true。
ONERING_RECORD_ONLY=false


# ─────────────────────────────────────────────────────────────
# Diff / 去重 / 编辑识别
# ─────────────────────────────────────────────────────────────

# 未知消息比例阈值。
# 当 post 中无法与数据库历史对齐的消息比例超过该值时，OneRing 放弃跨端补充。
#
# 注意：
# - 全新上下文只有 1~2 条 user/assistant 发言时会特殊豁免。
# - 该值越低越保守。
ONERING_MAX_UNKNOWN_RATIO=0.35

# fuzzy 去重/匹配阈值。
# 用于判断 retry、重新发送、轻微编辑后是否仍然是同一条消息。
#
# 推荐范围：
#   0.90 ~ 0.95
#
# 默认 0.92 是较保守的折中值。
ONERING_DEDUP_SIMILARITY=0.92


# 每个 Agent/frontend 的 post 快照尾部窗口大小。
# 用于识别“用户编辑旧上下文后 retry”的场景。
# 默认 20；只保存最近同端 post 的尾部块，不会无限增长。
ONERING_POST_SNAPSHOT_MAX_BLOCKS=20

# 最终输出相邻同 role 近重复去重阈值。
# 用于避免当前上下文块与 DB 补齐块几乎重复并相邻出现。
# 默认 0.98 较保守，只清理高度相似的相邻 user/user 或 assistant/assistant。
ONERING_OUTPUT_DEDUP_SIMILARITY=0.98


# 每个 Agent 的 SQLite 消息保留上限。
# 默认 100 条；设为 0 或负数表示不限制。
# 注意：实际注入上下文仍由 OneRingConfig.json 的 maxContextBlocks 控制，通常只取最近 10/20 个 block。
ONERING_MAX_DB_RECORDS=100


# ─────────────────────────────────────────────────────────────
# 调试
# ─────────────────────────────────────────────────────────────

# 是否输出 OneRing 调试日志。
# PluginManager 会将 DebugMode 注入插件配置；这里可单独覆盖。
DebugMode=false
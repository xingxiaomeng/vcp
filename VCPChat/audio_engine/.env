# VCP Hi-Fi Audio Engine Configuration

# 默认 EQ 模式: FIR 或 IIR
VCP_AUDIO_EQ_TYPE=FIR

# 默认目标升频采样率 (例如: 48000, 96000, 192000)
# 设置为空则使用原始采样率（推荐，避免与输出设备不匹配导致崩溃）
# VCP_AUDIO_TARGET_SAMPLERATE=192000
VCP_AUDIO_TARGET_SAMPLERATE=

# 是否启用重采样磁盘缓存 (true/false)
VCP_AUDIO_USE_CACHE=false

# 是否启用“抢跑”重采样 (Preemptive Resampling)
# 关闭后由播放设备实时重采样，兼容性更好
VCP_AUDIO_PREEMPTIVE_RESAMPLE=false

# 重采样质量档位 (low, std, hq, 最新版可以用这个档位uhq)
# uhq 模式下 sinc 长度更长，插值更精确，但计算量更大
VCP_AUDIO_RESAMPLE_QUALITY=hq

# 重采样缓存目录 (可选，若不设置则使用命令行参数)
# VCP_AUDIO_CACHE_DIR=./resample_cache
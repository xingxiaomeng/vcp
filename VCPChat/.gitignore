gitignore

# 不忽略 .gitignore 文件本身（这是Git的常见实践）
!.gitignore

AppData/

node_modules/

.env
!audio_engine/.env

/public/assets

**/.DS_Store

# Rust build artifacts
**/target/
**/Cargo.lock
rust_audio_engine/.cargo/

# Reports and logs
**/reports/

# 临时忽略的文件（本地修改，不提交）
.npmrc
modules/ipc/chatHandlers.js
modules/itemListManager.js
modules/settingsManager.js
package-lock.json
package.json
styles/themes.css

# LibreHardwareMonitor 官方二进制由开发者本地自行准备，不进入仓库
vendor/LibreHardwareMonitor/*
!vendor/LibreHardwareMonitor/README.md

# 忽略 WebIndexTTS2 生成输出目录
/WebIndexTTS2/tmp-output/

# rust_audio_engine 运行时缓存（响度分析等）
loudness_cache.db
loudness_cache.db-journal
loudness_cache.db-wal
loudness_cache.db-shm


# AI CLI local state/config directories
**/.snow/
**/.claude/
**/.codex/

/开发文档/

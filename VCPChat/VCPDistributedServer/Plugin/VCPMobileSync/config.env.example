# ============================================================
# VCPMobileSync 插件配置
# ============================================================
#
# 本插件让 VCPChat 桌面端与 VCPMobile 手机端保持数据同步。
# 只需修改下面两项即可，其余为说明注释。
# ============================================================


# -------- 同步密码（必填）--------
#
# 手机端连接时必须输入此密码，建议设得复杂一些。
# 电脑和手机两边的密码必须完全一致才能同步。
#
MobileSyncToken=your_super_secret_token_here


# -------- 同步端口（必填）--------
#
# 本插件独立使用的端口，默认 5975，一般不用改。
# 手机端设置里的「WebSocket 服务 URL」就是填这个端口。
#
# ⚠️ 不要和 VCPDistributedServer 的端口搞混！
#   · 本插件端口（MobileSyncPort）= 5975  → 手机端「WebSocket 服务 URL」
#   · 分布式服务器端口（DIST_SERVER_PORT）→ 在 VCPDistributedServer/config.env 里定义
#                                           → 默认 5974
#                                           → 手机端「HTTP 服务 URL」
#
MobileSyncPort=5975


# ============================================================
# 手机端配置速查
# ============================================================
#
# 打开手机端 VCPMobile → 设置 → 同步设置：
#
#   HTTP 服务 URL      = http://<电脑IP/域名>:<分布式服务器端口>
#                        					↑ 来源：VCPDistributedServer/config.env 里的 DIST_SERVER_PORT
#                        					↑ 默认值：5974
#
#   WebSocket 服务 URL = ws://<电脑IP/域名>:<本插件端口>
#                        					↑ 来源：本文件上面的 MobileSyncPort
#                        					↑ 默认值：5975
#
#   Mobile Sync Token  = 和本文件上面的 MobileSyncToken 完全一致
#
# -------- 示例（假设电脑 IP 为 192.168.1.100, 支持域名）--------
#
#   HTTP 服务 URL      = http://192.168.1.100:5974
#   WebSocket 服务 URL = ws://192.168.1.100:5975
#
# ============================================================
